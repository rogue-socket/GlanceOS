# Remote backend URL (recommended for multi-machine setups)
# Example: VITE_BACKEND_URL=http://192.168.1.25:8000
VITE_BACKEND_URL=

# Explicit websocket URL override (optional)
# Example: VITE_WS_URL=ws://192.168.1.25:8000/ws
VITE_WS_URL=

# Vite proxy targets (used only when proxy is enabled)
VITE_PROXY_API_TARGET=http://127.0.0.1:8000
VITE_PROXY_WS_TARGET=ws://127.0.0.1:8000

# Set true to disable Vite /api and /ws proxy completely
VITE_DISABLE_PROXY=false
