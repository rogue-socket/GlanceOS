# GlanceOS Backend Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=WARNING

# API Keys (add your own)
WEATHER_API_KEY=
GITHUB_TOKEN=
TODOIST_API_TOKEN=
NEWS_LLM_API_KEY=

# Google Calendar (use either ICS URL OR Calendar ID + API key)
GOOGLE_CALENDAR_ICS_URL=
GOOGLE_CALENDAR_ID=
GOOGLE_CALENDAR_API_KEY=

# News crux summarization (Gemini by default)
NEWS_USE_LLM=true
NEWS_LLM_PROVIDER=gemini
NEWS_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
NEWS_LLM_MODEL=gemini-2.0-flash-lite
NEWS_LLM_TIMEOUT_SECONDS=12

# Widget defaults
WEATHER_CITY=Hyderabad,IN
GITHUB_USERNAME=octocat

# Database
DATABASE_URL=sqlite+aiosqlite:///./glanceos.db
